{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "bc",
      "camelcase": "Bc",
      "title": "bc",
      "scope": "source.bc",
      "file-types": ["b", "bc"],
      "injection-regex": "^bc$",
      "class-name": "TreeSitterBc",
      "highlights": ["queries/highlights.scm"]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "GPL-3.0-or-later",
    "description": "GNU bc 1.07.1 grammar for tree-sitter",
    "authors": [
      {
        "name": "bc-lean contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/vzaliva/bc-lean"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
